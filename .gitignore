/*

!.gitignore
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/our-family-passport/
!wp-content/themes/our-family-passport/**

# Dependencies — full paths required due to ** whitelist above
wp-content/themes/our-family-passport/vendor/
wp-content/themes/our-family-passport/node_modules/

# WordPress generated
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/

# Compiled assets
*.css.map
style.css.map

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Editor
.vscode/
.idea/

# Distribution
*.zip
