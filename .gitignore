# Ignorar tudo
/*

# Exceto o tema (e o próprio .gitignore)
!.gitignore
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/our-family-passport/
!wp-content/themes/our-family-passport/**

# Opcional: ignorar também plugins de terceiros, uploads, etc
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/

# Dependencies
node_modules/
vendor/

# Compiled assets (if you compile locally and don't want maps in repo)
*.css.map
style.css.map

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Editor
.vscode/
.idea/

# Distribution
*.zip
